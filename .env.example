APP_NAME=Makasouk
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=makasouk
DB_USERNAME=postgres
DB_PASSWORD=postgres

BROADCAST_CONNECTION=reverb
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

SANCTUM_STATEFUL_DOMAINS=127.0.0.1:8000,localhost:8000

PHONE_VERIFICATION_DRIVER=log
PHONE_VERIFICATION_EXPIRES_MINUTES=10
PHONE_VERIFICATION_RESEND_COOLDOWN=60
PHONE_VERIFICATION_TIMEOUT_SECONDS=10
PHONE_VERIFICATION_LOG_CHANNEL=stack
PHONE_VERIFICATION_EXPOSE_CODE_IN_LOGS=false
BREVO_SMS_API_KEY=
BREVO_SMS_SENDER=MAKASOUK
BREVO_SMS_ENDPOINT=https://api.brevo.com/v3/transactionalSMS/sms
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
MESSAGEBIRD_API_KEY=
MESSAGEBIRD_ORIGINATOR=MAKASOUK
MESSAGEBIRD_ENDPOINT=https://rest.messagebird.com/messages

REVERB_APP_ID=makasouk-app
REVERB_APP_KEY=makasouk-key
REVERB_APP_SECRET=makasouk-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_ALLOWED_ORIGINS=*

VITE_SPA_BASE=/app/
VITE_API_BASE_URL=/api
VITE_BROADCAST_AUTH_ENDPOINT=/broadcasting/auth
VITE_REVERB_KEY=makasouk-key
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
